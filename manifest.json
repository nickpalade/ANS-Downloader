{
  "manifest_version": 3,
  "name": "ANS Downloader",
  "version": "2.0",

  "description": "Download your exams and answers as PDF from ANS.",

  "host_permissions": [
    "*://*.ans.app/*",
    "*://*.objectstore.eu/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.ans.app/*"],
      "js": ["html2pdf.bundle.js", "downloader.js"]
    }
  ]
}
