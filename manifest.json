{
  "manifest_version": 3,
  "name": "ANS Downloader",
  "version": "2.0",

  "description": "Download your exams and answers as PDF from ANS.",

  "browser_specific_settings": {
    "gecko": {
      "id": "ans-downloader@nickpalade",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },

  "host_permissions": [
    "*://*.ans.app/*",
    "*://*.objectstore.eu/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.ans.app/*"],
      "js": ["downloader.js"]
    }
  ]
}
